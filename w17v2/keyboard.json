{   
    "keyboard_name": "W17PADV2",
    "maintainer": "NUTWANG",
    "manufacturer": "NUTWANG",
    "url": "https://oshwhub.com/morempty",
    "tags":["rgb","pad"],

    "processor": "STM32F072",
    "bootloader": "stm32-dfu",

     "features": {
        "bootmagic": true,
        "rgb_matrix": true,
        "rgblight": false,
        "command": false,
        "console": false,
        "extrakey": true,
        "mousekey": true,
        "nkro": true
    },
    "qmk": {
        "locking": {
            "enabled": true,
            "resync": true
        }
    },
    
    "bootmagic":{
        "enabled":true,
        "matrix":[0,0]
    },


    "ws2812": {
        "driver": "pwm",
        "pin": "A8"
    },

    "rgb_matrix":{
        "animations":{
            "alphas_mods": true,
            "gradient_up_down":true,
            "gradient_left_right":true,
            "breathing": true,
            "band_sat":true,
            "band_val":true,
            "band_pinwheel_sat":true,
            "band_pinwheel_val":true,
            "band_spiral_sat":true,
            "band_spiral_val":true,
            "cycle_all":true,
            "cycle_left_right": true,
            "cycle_up_down":true,
            "cycle_out_in":true,
            "cycle_out_in_dual":true,
            "rainbow_moving_chevron":true,
            "cycle_pinwhee":true,
            "cycle_spiral":true,
            "dual_beacon":true,
            "rainbow_beacon":true,
            "rainbow_pinwheels":true,
            "flower_blooming":true,
            "raindrop":true,
            "jellybean_raindrops":true,
            "hue_breathing":true,
            "hue_pendulum":true,
            "hue_wave":true,
            "pixel_fractal":true,
            "pixel_flow":true,
            "pixel_rain":true
        },
        "center_point":[112,32],
        "deault":{
            "on": true,
            "hue":0,
            "sat":255,
            "val":200,
            "speed":128
        },
        "driver":"ws2812",
        "hue_steps":8,
        
        "layout":[
            {"matrix": [0, 0], "x": 28, "y": 3, "flags": 4},
            {"matrix": [0, 1], "x": 84, "y": 3, "flags": 4},
            {"matrix": [0, 2], "x": 140, "y": 3, "flags": 4},
            {"matrix": [0, 3], "x": 196, "y": 3, "flags": 4},

            {"matrix": [1, 0], "x": 28, "y": 16, "flags": 4},
            {"matrix": [1, 1], "x": 84, "y": 16, "flags": 4},
            {"matrix": [1, 2], "x": 140, "y": 16, "flags": 4},

            {"matrix": [2, 0], "x": 28, "y": 29, "flags": 4},
            {"matrix": [2, 1], "x": 84, "y": 29, "flags": 4},
            {"matrix": [2, 2], "x": 140, "y": 29, "flags": 4},
            {"matrix": [1, 3], "x": 182, "y": 26, "flags": 4},
           

            {"matrix": [3, 0], "x": 28, "y": 41, "flags": 4},
            {"matrix": [3, 1], "x": 84, "y": 41, "flags": 4},
            {"matrix": [3, 2], "x": 140, "y": 41, "flags": 4},

            {"matrix": [4, 0], "x": 56, "y": 54, "flags": 4},
            {"matrix": [4, 4], "x": 140, "y": 54, "flags": 4},
            {"matrix": [3, 4], "x": 182, "y": 51, "flags": 4}
          
        ],
        "led_flush_limit":16,
        "led_process_limit":17,
        "max_brightness":255,
        "react_on_keyup":false,
        "sat_steps":16,
        "speed_steps":16,
        "val_steps":16,
        "sleep":true,
        "timeout":0
        },

    

    "usb": {
        "device_version": "0.0.2",
        "pid": "0x0194",
        "vid": "0x0463"
    },


    "diode_direction": "COL2ROW",
    "matrix_pins": {
        "rows": ["B4", "B3", "A15", "B2", "B0"],
        "cols": ["A6", "B10", "B1", "B5", "A7"]
    },
    "layout_aliases": {
        "LAYOUT_all": "LAYOUT"
    },
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"label":"Num Lock","matrix": [0, 0], "x": 0, "y": 0,"w":1,"h":1},
                {"label":"/","matrix": [0, 1], "x": 1, "y": 0,"w":1,"h":1},
                {"label":"*","matrix": [0, 2], "x": 2, "y": 0,"w":1,"h":1},
                {"label":"-","matrix": [0, 3], "x": 3, "y": 0,"w":1,"h":1},

                {"label":"7","matrix": [1, 0], "x": 0, "y": 1,"w":1,"h":1},
                {"label":"8","matrix": [1, 1], "x": 1, "y": 1,"w":1,"h":1},
                {"label":"9","matrix": [1, 2], "x": 2, "y": 1,"w":1,"h":1},
                {"label":"+","matrix": [1, 3], "x": 3, "y": 1.5,"w":1,"h":2},

                {"label":"4","matrix": [2, 0], "x": 0, "y": 2,"w":1,"h":1},
                {"label":"5","matrix": [2, 1], "x": 1, "y": 2,"w":1,"h":1},
                {"label":"6","matrix": [2, 2], "x": 2, "y": 2,"w":1,"h":1},

                {"label":"1","matrix": [3, 0], "x": 0, "y": 3,"w":1,"h":1},
                {"label":"2","matrix": [3, 1], "x": 1, "y": 3,"w":1,"h":1},
                {"label":"3","matrix": [3, 2], "x": 2, "y": 3,"w":1,"h":1},
                {"label":"Enter","matrix": [3, 4], "x": 3, "y": 3.5,"w":1,"h":2},

                {"label":"0","matrix": [4, 0], "x": 2, "y": 0,"w":2,"h":1},
                {"label":".","matrix": [4, 4], "x": 2, "y": 0,"w":1,"h":1}
            ]
        }
    }
}
